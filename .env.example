# OpenAI API key (required for the pipeline and evals).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override OpenAI API base URL (default: https://api.openai.com/v1).
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: used by the Gradio UI to call the API (default: http://localhost:8000).
# API_URL=http://localhost:8000

# Optional: model for pipeline agents (default: gpt-4o).
# OPENAI_MODEL=gpt-4o
